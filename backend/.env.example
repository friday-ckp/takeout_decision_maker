# ============================================================
# 外卖点餐决策器 - 环境变量配置示例
# 使用方法：复制本文件为 .env，填入实际值后启动服务
# cp .env.example .env
# ============================================================

# ---- 数据库配置（必填）----
DB_HOST=127.0.0.1          # MySQL 主机地址
DB_PORT=3306               # MySQL 端口，默认 3306
DB_USER=root               # 数据库用户名
DB_PASSWORD=your_password  # 数据库密码
DB_NAME=takeout_decision   # 数据库名称（需提前创建）

# ---- 服务配置（可选）----
PORT=3000                  # 后端服务监听端口，默认 3000
NODE_ENV=development       # 运行环境：development | production

# ---- 会话配置（可选）----
SESSION_SECRET=change_me_to_a_random_string  # 多人会话 token 签名密钥，建议32位随机字符串
SESSION_EXPIRE_HOURS=24    # 多人会话有效期（小时），默认 24

# ---- 部署配置（可选）----
APP_BASE_URL=http://localhost:3000  # 应用外部访问地址，用于生成多人分享链接，生产部署时必须修改
# DEFAULT_USER_NAME=Friday           # 默认单用户昵称，用于多人会话中的发起人显示名

# ---- JWT 认证（Story 8.4，可选）----
JWT_SECRET=your-secret-key-here    # JWT 签名密钥，生产环境必须替换为32位以上随机字符串
